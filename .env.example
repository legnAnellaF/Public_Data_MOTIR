OPENAI_API_KEY=
OPENAI_KEYWORD_MODEL=gpt-5.4-mini
# 모델명은 계정/시점에 따라 환경에 맞게 조정 가능
# GOOGLE_API_KEY=

GOOGLE_API_KEY=

# 공공데이터포털 검색 API 설정(실제 키는 .env 또는 서버 환경 변수에만 저장)
PUBLIC_DATA_API_KEY=your-public-data-api-key
# 실제 데이터셋 검색 endpoint 확인 후 필요 시 덮어쓰기
PUBLIC_DATA_PORTAL_BASE_URL=https://api.odcloud.kr/api
